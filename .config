# 目标平台 - IPQ8074
CONFIG_TARGET_ipq807x=y
CONFIG_TARGET_ipq807x_generic=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_ALL_PROFILES=y

# Linux 内核版本
CONFIG_LINUX_5_15=y

# 启用 64 位支持
CONFIG_ARCH_64BIT=y

# 基本设置
CONFIG_BUILD_PATENTED=y
CONFIG_BUILD_NLS=y

# 启用 LuCI Web 界面
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-proto-ipv6=y

# 中文语言包
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y

# USB 支持
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y

# 5G 模块支持 (Quectel 等)
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-serial-wwan=y
CONFIG_PACKAGE_kmod-mhi=y
CONFIG_PACKAGE_kmod-mhi-pci-generic=y

# QMI 协议支持
CONFIG_PACKAGE_uqmi=y
CONFIG_PACKAGE_libqmi=y
CONFIG_PACKAGE_qmi-utils=y

# PCIe 支持 (NVMe)
CONFIG_PACKAGE_kmod-pcie-qcom=y
CONFIG_PACKAGE_kmod-nvme=y

# 网络工具
CONFIG_PACKAGE_iwinfo=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y

# 文件系统支持
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ntfs=y
CONFIG_PACKAGE_kmod-fs-exfat=y

# Samba 文件共享 (供 NAS 使用)
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_samba4-client=y
CONFIG_PACKAGE_samba4-libs=y

# 常用工具
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_nmap=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_screen=y
CONFIG_PACKAGE_tmux=y

# 内核调试（可选，方便排查问题）
CONFIG_DEVEL=y
CONFIG_KERNEL_DEBUG_INFO=y
