# ========================================
# IPQ8074 5G CPE 完整配置
# 适用架构：qualcommax_ipq807x
# 生成日期：2026-06-08
# ========================================

# ---------- 目标平台 ----------
CONFIG_TARGET_ipq807x=y
CONFIG_TARGET_ipq807x_generic=y
CONFIG_TARGET_ipq807x_generic_DEVICE_xiaomi_ax3600=y

# ---------- 内核 ----------
CONFIG_LINUX_5_15=y
CONFIG_ARCH_64BIT=y

# ---------- 基础功能 ----------
CONFIG_BUILD_PATENTED=y
CONFIG_BUILD_NLS=y

# ---------- LuCI Web界面 + 中文 ----------
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y

# ========== 以下为常用插件配置 ==========

# ---------- 1. QuickStart 快速设置向导 ----------
CONFIG_PACKAGE_luci-app-quickstart=y
CONFIG_PACKAGE_luci-i18n-quickstart-zh-cn=y

# ---------- 2. iStore / HomeBox 应用商店 ----------
CONFIG_PACKAGE_luci-app-store=y
CONFIG_PACKAGE_luci-app-homebox=y
CONFIG_PACKAGE_luci-i18n-homebox-zh-cn=y

# ---------- 3. UU加速器（游戏加速）----------
CONFIG_PACKAGE_luci-app-uu=y
CONFIG_PACKAGE_luci-i18n-uu-zh-cn=y

# ---------- 4. PassWall（代理工具）----------
# 注意：需要确保 DIY 脚本正确拉取源码
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_luci-app-passwall_Iptables_Transparent_Proxy=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Libev_Client=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_ShadowsocksR_Libev_Client=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray_Plugin=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=y

# ---------- 5. OpenClash ----------
CONFIG_PACKAGE_luci-app-openclash=y

# ---------- 6. USB支持 ----------
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y

# ---------- 7. 5G模块驱动 ----------
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-serial-wwan=y
CONFIG_PACKAGE_kmod-mhi=y
CONFIG_PACKAGE_kmod-mhi-pci-generic=y
CONFIG_PACKAGE_uqmi=y
CONFIG_PACKAGE_libqmi=y

# ---------- 8. PCIe + NVMe驱动 ----------
CONFIG_PCI=y
CONFIG_PCI_MSI=y
CONFIG_PCIE_QCOM=y
CONFIG_NVME_CORE=y
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_PCI=y

# ---------- 9. 文件系统（挂载硬盘用）----------
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ntfs=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_luci-app-diskman=y

# ---------- 10. Samba文件共享（NAS）----------
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_samba4-client=y
CONFIG_PACKAGE_samba4-libs=y
CONFIG_PACKAGE_luci-app-samba4=y

# ---------- 11. 其他常用工具 ----------
CONFIG_PACKAGE_iwinfo=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_htop=y
